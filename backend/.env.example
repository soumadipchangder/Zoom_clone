# ── Backend Environment Variables ──────────────────────────────────────
# Copy this to .env and fill in the values

# A long random secret for signing JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_to_a_random_secret_string

# SQLite (default for local dev / HF Spaces free tier)
# For production Postgres: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./zoomclone.db

# Your deployed frontend URL (e.g. https://yourapp.vercel.app)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
